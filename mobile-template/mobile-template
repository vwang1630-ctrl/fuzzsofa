    /* ============================================================
       AR 编辑模式
       ============================================================ */
    .ar-overlay {
      position: fixed;
      inset: 0;
      z-index: 400;
      display: none;
      background: #0A0A0A;
      flex-direction: column;
    }
    .ar-overlay.open { display: flex; }

    .ar-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 20px;
      background: rgba(10,10,10,0.9);
      backdrop-filter: blur(12px);
      z-index: 10;
      border-bottom: 0.5px solid rgba(255,255,255,0.04);
      flex-shrink: 0;
    }
    .ar-header .ar-back {
      background: none;
      border: none;
      color: #8A8580;
      font-size: 14px;
      cursor: pointer;
      font-family: inherit;
      letter-spacing: 0.04em;
      padding: 4px 0;
      transition: color 0.2s;
    }
