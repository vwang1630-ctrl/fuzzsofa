    // ============================================================
    // 2. 语言下拉菜单
    // ============================================================
    let currentLang = 'zh';
    const langToggle = document.getElementById('langToggle');
    const langMenu = document.getElementById('langMenu');
    const langArrow = document.getElementById('langArrow');
    const langBackdrop = document.getElementById('langBackdrop');
    const currentLangLabel = document.getElementById('currentLangLabel');
    let langOpen = false;

    function renderLangMenu() {
      langMenu.innerHTML = '';
      LANGUAGES.forEach(lang => {
        const btn = document.createElement('button');
        btn.className = 'menu-item' + (lang.code === currentLang ? ' active' : '');
        btn.dataset.code = lang.code;
        btn.textContent = lang.label;
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          setLanguage(this.dataset.code);
          closeLangMenu();
        });
        langMenu.appendChild(btn);
      });
    }

    function openLangMenu() {
      langOpen = true;
      langMenu.classList.add('open');
      langArrow.classList.add('open');
      langBackdrop.classList.add('open');
    }
    function closeLangMenu() {
      langOpen = false;
      langMenu.classList.remove('open');
      langArrow.classList.remove('open');
      langBackdrop.classList.remove('open');
    }
    function toggleLangMenu() {
      langOpen ? closeLangMenu() : openLangMenu();
    }

    langToggle.addEventListener('click', function(e) { e.stopPropagation(); toggleLangMenu(); });
    langBackdrop.addEventListener('click', closeLangMenu);

    // ============================================================
    // 3. 分享下拉菜单
    // ============================================================
    const shareDropdown = document.getElementById('shareDropdown');
    const shareToggle = document.getElementById('shareToggle');
    const shareMenu = document.getElementById('shareMenu');
    const shareBackdrop = document.getElementById('shareBackdrop');
    let shareOpen = false;

    function openShareMenu() {
      shareOpen = true;
      shareMenu.classList.add('open');
      shareBackdrop.classList.add('open');
    }
    function closeShareMenu() {
      shareOpen = false;
      shareMenu.classList.remove('open');
      shareBackdrop.classList.remove('open');
    }
    function toggleShareMenu() {
      shareOpen ? closeShareMenu() : openShareMenu();
    }

    shareToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      toggleShareMenu();
    });
    shareBackdrop.addEventListener('click', closeShareMenu);

    shareMenu.querySelectorAll('.menu-item').forEach(item => {
      item.addEventListener('click', function(e) {
        e.stopPropagation();
        const action = this.dataset.action;
        const url = window.location.href;
        const title = 'Meteorite Ring Sofa';
        const img = document.getElementById('mainImage');

        switch (action) {
          case 'copy':
            if (navigator.clipboard) {
              navigator.clipboard.writeText(url).then(() => {
                alert(currentLang === 'zh' ? '✅ 链接已复制' : '✅ Link copied');
              }).catch(() => {
                prompt(currentLang === 'zh' ? '复制以下链接：' : 'Copy this link:', url);
              });
            } else {
              prompt(currentLang === 'zh' ? '复制以下链接：' : 'Copy this link:', url);
            }
            break;
          case 'save':
            if (img) {
              const link = document.createElement('a');
              link.download = 'meteorite-ring-sofa.jpg';
              link.href = img.src;
              document.body.appendChild(link);
              link.click();
              document.body.removeChild(link);
            }
            break;
          case 'facebook':
            window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url), '_blank');
            break;
          case 'twitter':
            window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(title) + '&url=' + encodeURIComponent(url), '_blank');
