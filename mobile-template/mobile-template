      const touch = e.changedTouches[0];
      dragStartX = touch.clientX;
      dragStartY = touch.clientY;
      isDragging = true;
      this.style.transition = 'none';
    }, { passive: true });

    document.addEventListener('touchmove', function(e) {
      if (!isDragging) return;
      const touch = e.changedTouches[0];
      const dx = touch.clientX - dragStartX;
      const dy = touch.clientY - dragStartY;
      const parentRect = arProduct.parentElement.getBoundingClientRect();
      const currentBottom = parseFloat(arProduct.style.bottom) || 25;
      const newBottom = currentBottom - (dy / parentRect.height) * 30;
      arProduct.style.bottom = Math.max(5, Math.min(70, newBottom)) + '%';
      dragStartX = touch.clientX;
      dragStartY = touch.clientY;
    }, { passive: true });

