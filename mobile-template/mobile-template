      '/products/meteorite-ring-sofa/scene-2.jpg'
    ];
    const dots = document.querySelectorAll('#indicator span');
    const mainImg = document.getElementById('mainImage');
    const hero = document.getElementById('heroImage');
    let cur = 0;
    let isDraggingImg = false;
    let startX = 0, startY = 0;

    function show(i) {
      cur = (i + imgs.length) % imgs.length;
      mainImg.src = imgs[cur];
      dots.forEach((d, j) => d.classList.toggle('active', j === cur));
    }
    dots.forEach((d, i) => {
      d.addEventListener('click', function(e) { e.stopPropagation(); show(i); });
    });
    mainImg.addEventListener('click', function() { if (isDraggingImg) return; show(cur + 1); });
    hero.addEventListener('touchstart', function(e) {
      const t = e.changedTouches[0];
      startX = t.screenX; startY = t.screenY; isDraggingImg = false;
    }, { passive: true });
    hero.addEventListener('touchmove', function(e) {
      const t = e.changedTouches[0];
      const dx = t.screenX - startX, dy = t.screenY - startY;
      if (Math.abs(dx) > 10 || Math.abs(dy) > 10) isDraggingImg = true;
    }, { passive: true });
    hero.addEventListener('touchend', function(e) {
      const t = e.changedTouches[0];
      const dx = startX - t.screenX, dy = startY - t.screenY;
      if (Math.abs(dx) > 30 && Math.abs(dx) > Math.abs(dy)) show(dx > 0 ? cur + 1 : cur - 1);
      setTimeout(() => { isDraggingImg = false; }, 100);
    }, { passive: true });

    // 颜色（页面内颜色选择）
    document.querySelectorAll('.color-selector .color-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.color-selector .color-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const color = this.dataset.color;
        mainImg.src = color === 'white'
          ? '/products/meteorite-ring-sofa/snowy-white.png'
          : '/products/meteorite-ring-sofa/gray.jpg';
      });
    });

    // 单位切换
    const unitBtns = document.querySelectorAll('#unitToggle button');
    const specValues = document.querySelectorAll('#specsContainer .v');
    unitBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        unitBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const unit = this.dataset.unit;
        specValues.forEach(el => {
          const val = el.dataset[unit];
          if (val) el.textContent = val + ' ' + unit;
        });
      });
    });

    // 个人中心（头像）
    document.querySelector('.avatar').addEventListener('click', function() {
      // 已在上方 avatarBtn 处理
    });

    // ============================================================
    // 8. 初始化
    // ============================================================
    let savedLang = 'zh';
    try { savedLang = localStorage.getItem('fuzz-lang') || 'zh'; } catch(e) {}
    renderLangMenu();
    setLanguage(savedLang);
    updateCartBadge();
    document.getElementById('favBadge').textContent = '0';

    console.log('✅ 完整页面已加载 — 含确认单 + 个人中心');
  })();
</script>
</body>
</html>