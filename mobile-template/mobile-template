    .ar-header .ar-done {
      background: none;
      border: none;
      color: #E8B4B8;
      font-size: 14px;
      cursor: pointer;
      font-family: inherit;
      letter-spacing: 0.04em;
      padding: 4px 0;
      transition: color 0.2s;
      font-weight: 400;
    }
    .ar-header .ar-done:active { color: #F5F0EB; }

    .ar-scene {
      flex: 1;
      position: relative;
      overflow: hidden;
      background: #0A0A0A;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .ar-scene .room-bg {
      width: 100%;
      height: 100%;
      object-fit: cover;
      position: absolute;
      inset: 0;
      background: #1A1A1A;
    }
    .ar-product-overlay {
      position: absolute;
      bottom: 25%;
      left: 50%;
      transform: translateX(-50%) scale(0.8);
      width: 50%;
      aspect-ratio: 1 / 0.8;
      pointer-events: none;
      transition: all 0.3s ease;
      opacity: 0.9;
    }
    .ar-product-overlay img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      filter: drop-shadow(0 8px 30px rgba(0,0,0,0.5));
    }

    .ar-hint {
      position: absolute;
      bottom: 80px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 12px;
      color: rgba(255,255,255,0.3);
      font-weight: 300;
      letter-spacing: 0.06em;
      background: rgba(10,10,10,0.5);
      padding: 6px 16px;
      border-radius: 20px;
      backdrop-filter: blur(4px);
      border: 0.5px solid rgba(255,255,255,0.03);
      white-space: nowrap;
      text-align: center;
    }
    .ar-hint .hint-sub {
      display: block;
      font-size: 10px;
      color: rgba(255,255,255,0.15);
      margin-top: 2px;
    }

    .ar-controls {
      position: absolute;
      bottom: 16px;
      left: 0;
      right: 0;
      padding: 0 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      background: rgba(10,10,10,0.6);
      backdrop-filter: blur(8px);
      padding: 12px 16px;
      margin: 0 16px;
      border-radius: 8px;
      border: 0.5px solid rgba(255,255,255,0.03);
    }
    .ar-controls .control-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px;
      flex: 1;
    }
    .ar-controls .control-item .ctrl-label {
      font-size: 9px;
      color: #6A6560;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 300;
    }
    .ar-controls .control-item .ctrl-value {
      font-size: 14px;
      color: #F5F0EB;
      font-weight: 400;
    }
    .ar-controls .control-item .ctrl-slider {
      width: 100%;
      height: 2px;
      -webkit-appearance: none;
      appearance: none;
      background: rgba(255,255,255,0.08);
      border-radius: 1px;
      outline: none;
      margin-top: 2px;
    }
    .ar-controls .control-item .ctrl-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #E8B4B8;
      cursor: pointer;
      border: 2px solid #0A0A0A;
    }
    .ar-controls .control-item .ctrl-slider::-moz-range-thumb {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #E8B4B8;
      cursor: pointer;
      border: 2px solid #0A0A0A;
    }

    .ar-product-label {
      position: absolute;
      bottom: 140px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 11px;
      color: rgba(255,255,255,0.15);
      font-weight: 300;
      letter-spacing: 0.06em;
      text-align: center;
      white-space: nowrap;
    }
    .ar-product-label strong {
      color: rgba(255,255,255,0.3);
      font-weight: 400;
    }

