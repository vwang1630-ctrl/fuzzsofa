<!DOCTYPE html>
<html lang="zh-CN" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  <title>Meteorite Ring Sofa · Fuzz Sofa</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    body {
      font-family: "PingFang SC", -apple-system, "Helvetica Neue", system-ui, sans-serif;
      background: #0A0A0A;
      color: #F5F0EB;
      display: flex;
      justify-content: center;
      min-height: 100vh;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    .container {
      width: 100%;
      max-width: 430px;
      background: #0A0A0A;
      padding: 0 20px 110px;
      position: relative;
    }

    .icon {
      display: block;
      width: 22px;
      height: 22px;
      stroke: #8A8580;
      stroke-width: 1.2;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: stroke 0.25s ease;
      flex-shrink: 0;
    }
    .icon-white { stroke: #6A6560; }
    .icon-gold { stroke: #E8B4B8; }

    /* ===== 顶部导航 ===== */
    .masthead {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0 16px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      margin-bottom: 24px;
      position: relative;
    }
    .masthead .brand {
      font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
      font-size: 18px;
      font-weight: 500;
      letter-spacing: 0.12em;
      color: #F5F0EB;
    }
    .masthead .brand em {
      font-style: normal;
      color: #6A6560;
      font-size: 10px;
      letter-spacing: 0.2em;
      margin-left: 10px;
      font-weight: 300;
    }
    .masthead .cart-link {
      color: #8A8580;
      font-size: 12px;
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color 0.2s;
      cursor: pointer;
      padding: 4px 8px;
      font-weight: 300;
    }
    .masthead .cart-link:active { color: #E8B4B8; }

    /* ===== 语言下拉菜单 ===== */
    .lang-dropdown {
      position: relative;
      margin-left: 10px;
      user-select: none;
      z-index: 50;
    }
    .lang-dropdown .toggle {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      font-weight: 400;
      color: #8A8580;
      letter-spacing: 0.04em;
      padding: 4px 10px 4px 8px;
      border: 0.5px solid rgba(255,255,255,0.04);
      transition: border-color 0.3s;
      background: rgba(255,255,255,0.015);
      cursor: pointer;
    }
    .lang-dropdown .toggle:active { border-color: rgba(232,180,184,0.2); }
    .lang-dropdown .toggle .arrow {
      font-size: 8px;
      color: #6A6560;
      transition: transform 0.25s ease;
      margin-left: 2px;
    }
    .lang-dropdown .toggle .arrow.open { transform: rotate(180deg); }

    .lang-dropdown .menu {
      position: absolute;
      top: calc(100% + 6px);
      right: 0;
      min-width: 120px;
      background: #181818;
      border: 0.5px solid rgba(255,255,255,0.06);
      box-shadow: 0 12px 40px rgba(0,0,0,0.6);
      padding: 4px 0;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-4px);
      transition: all 0.2s ease;
      max-height: 260px;
      overflow-y: auto;
      border-radius: 0;
    }
    .lang-dropdown .menu.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .lang-dropdown .menu::-webkit-scrollbar { width: 0; }
    .lang-dropdown .menu-item {
      display: block;
      width: 100%;
      padding: 8px 16px;
      background: transparent;
      border: none;
      font-family: inherit;
      font-size: 13px;
      color: #8A8580;
      cursor: pointer;
      text-align: left;
      transition: all 0.15s ease;
    }
    .lang-dropdown .menu-item:active {
      background: rgba(232,180,184,0.06);
      color: #F5F0EB;
    }
    .lang-dropdown .menu-item.active {
      color: #E8B4B8;
      background: rgba(232,180,184,0.04);
    }
    .lang-backdrop {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: none;
    }
    .lang-backdrop.open { display: block; }

    .masthead .right {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .masthead .right button {
      background: none;
      border: none;
      padding: 4px;
      cursor: pointer;
      display: flex;
      align-items: center;
    }
    .masthead .right button:hover .icon { stroke: #E8B4B8; }
    .masthead .avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #161616;
      border: 1px solid rgba(255,255,255,0.04);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: border-color 0.25s;
    }
    .masthead .avatar:hover { border-color: rgba(232,180,184,0.3); }
    .masthead .avatar .icon { width: 16px; height: 16px; stroke: #6A6560; }

    /* ===== 图片区 ===== */
    .hero-image {
      width: calc(100% + 40px);
      margin-left: -20px;
      margin-right: -20px;
      aspect-ratio: 1 / 1;
      background: #0A0A0A;
      overflow: hidden;
      position: relative;
      margin-bottom: 24px;
      touch-action: pan-y;
      cursor: grab;
    }
    .hero-image:active { cursor: grabbing; }
    .hero-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      pointer-events: none;
    }

    .float-ai {
      position: absolute;
      top: 16px;
      left: 20px;
      z-index: 10;
    }
    .float-ai button {
      background: rgba(10,10,10,0.5);
      backdrop-filter: blur(6px);
      border: 0.5px solid rgba(232,180,184,0.2);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.25s ease;
    }
    .float-ai button:active { transform: scale(0.88); background: rgba(232,180,184,0.12); }
    .float-ai button .icon { stroke: #E8B4B8; }

    /* ---- 分享下拉菜单 ---- */
    .share-dropdown {
      position: absolute;
      top: 16px;
      right: 20px;
      z-index: 10;
    }
    .share-dropdown .share-toggle {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 0.5px solid rgba(255,255,255,0.06);
      background: rgba(10,10,10,0.5);
      backdrop-filter: blur(6px);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s ease;
      color: #E8B4B8;
    }
    .share-dropdown .share-toggle:active {
      transform: scale(0.88);
      background: rgba(232,180,184,0.08);
    }
    .share-dropdown .share-toggle svg {
      width: 20px;
      height: 20px;
      stroke: #E8B4B8;
      stroke-width: 1.5;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .share-dropdown .share-menu {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      min-width: 180px;
      background: #181818;
      border: 0.5px solid rgba(255,255,255,0.06);
      box-shadow: 0 12px 40px rgba(0,0,0,0.6);
      padding: 6px 0;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-6px) scale(0.96);
      transform-origin: top right;
      transition: all 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      z-index: 100;
      border-radius: 0;
    }
    .share-dropdown .share-menu.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0) scale(1);
    }

    .share-dropdown .share-menu .menu-item {
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
      padding: 10px 16px;
      background: transparent;
      border: none;
      font-family: inherit;
      font-size: 13px;
      color: #8A8580;
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: left;
      white-space: nowrap;
    }
    .share-dropdown .share-menu .menu-item:hover,
    .share-dropdown .share-menu .menu-item:active {
      background: rgba(232,180,184,0.06);
      color: #E8B4B8;
    }
    .share-dropdown .share-menu .menu-item svg {
      width: 18px;
      height: 18px;
      stroke: #6A6560;
      stroke-width: 1.5;
      fill: none;
      flex-shrink: 0;
      transition: stroke 0.2s ease;
    }
    .share-dropdown .share-menu .menu-item:hover svg,
    .share-dropdown .share-menu .menu-item:active svg {
      stroke: #E8B4B8;
    }
    .share-dropdown .share-menu .menu-divider {
      height: 0.5px;
      background: rgba(255,255,255,0.04);
      margin: 4px 12px;
    }

    .share-backdrop {
      position: fixed;
      inset: 0;
      z-index: 99;
      display: none;
    }
    .share-backdrop.open { display: block; }

    /* 收藏按钮（左上） */
    .float-actions {
      position: absolute;
      top: 16px;
      left: 20px;
      z-index: 10;
      display: flex;
      gap: 12px;
    }
    .float-actions button {
      background: rgba(10,10,10,0.5);
      backdrop-filter: blur(6px);
      border: 0.5px solid rgba(255,255,255,0.06);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
    }
    .float-actions button:active { transform: scale(0.88); background: rgba(232,180,184,0.08); }
    .float-actions button .icon {
      width: 20px;
      height: 20px;
      stroke: rgba(255,255,255,0.5);
    }
    .float-actions .faved .icon {
      stroke: #E8B4B8;
      fill: #E8B4B8;
    }

    .image-indicator {
      position: absolute;
      bottom: 16px;
      right: 20px;
      display: flex;
      gap: 8px;
      font-size: 10px;
      letter-spacing: 0.15em;
      color: rgba(255,255,255,0.15);
      background: rgba(10,10,10,0.4);
      padding: 4px 14px;
      border-radius: 30px;
      backdrop-filter: blur(4px);
      font-family: 'Cormorant Garamond', Georgia, serif;
      z-index: 5;
    }
    .image-indicator span { transition: color 0.3s; cursor: pointer; user-select: none; }
    .image-indicator span.active { color: #E8B4B8; }

    /* ===== 颜色选择器 ===== */
    .color-selector {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 0 0 18px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      margin-bottom: 24px;
    }
    .color-selector .label {
      font-size: 11px;
      color: #6A6560;
      letter-spacing: 0.08em;
      font-weight: 300;
    }
    .color-selector .options {
      display: flex;
      gap: 24px;
    }
    .color-selector .color-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 0;
      transition: all 0.25s ease;
      font-family: inherit;
      font-size: 12px;
      color: #6A6560;
      font-weight: 300;
      letter-spacing: 0.04em;
      position: relative;
    }
    .color-selector .color-btn .swatch-wrap {
      position: relative;
      display: inline-block;
    }
    .color-selector .color-btn .swatch {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.06);
      transition: all 0.3s ease;
      display: block;
    }
    .color-selector .color-btn .swatch-white { background: #F0EDE8; }
    .color-selector .color-btn .swatch-gray { background: #6A6A6A; }
    .color-selector .color-btn .check {
      position: absolute;
      top: -4px;
      right: -4px;
      width: 14px;
      height: 14px;
      background: #E8B4B8;
      border-radius: 50%;
      opacity: 0;
      transform: scale(0.5);
      transition: all 0.3s ease;
      border: 2px solid #0A0A0A;
    }
    .color-selector .color-btn.active .check {
      opacity: 1;
      transform: scale(1);
    }
    .color-selector .color-btn.active .swatch {
      border-color: #E8B4B8;
      box-shadow: 0 0 0 2px rgba(232,180,184,0.2);
    }
    .color-selector .color-btn.active { color: #F5F0EB; }
    .color-selector .color-btn:active { transform: scale(0.94); }
    .color-selector .color-btn .label-text { font-size: 11px; line-height: 1.2; }

    /* ===== 卖点 ===== */
    .features {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-bottom: 28px;
    }
    .feature-row {
      display: flex;
      align-items: baseline;
      gap: 12px;
      font-size: 14px;
      color: #8A8580;
      font-weight: 300;
      padding: 5px 0;
      border-bottom: 0.5px solid rgba(255,255,255,0.02);
    }
    .feature-row .num {
      font-size: 10px;
      color: #E8B4B8;
      font-weight: 400;
      width: 18px;
      flex-shrink: 0;
      font-family: 'Cormorant Garamond', Georgia, serif;
    }
    .feature-row .label { font-weight: 400; color: #F5F0EB; margin-right: 4px; }
    .feature-row .desc { color: #6A6560; font-size: 13px; }

    /* ===== 描述 ===== */
    .description {
      margin-bottom: 30px;
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .description p {
      font-size: 15px;
      line-height: 1.8;
      color: #8A8580;
      font-weight: 300;
      letter-spacing: 0.02em;
    }
    .description p .highlight { color: #E8B4B8; font-weight: 400; }

    /* ===== THE STORY ===== */
    .story {
      padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.04);
      margin-bottom: 30px;
    }
    .story .section-label {
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #6A6560;
      margin-bottom: 14px;
      font-weight: 300;
    }
    .story-grid {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .story-image {
      width: 100%;
      aspect-ratio: 4/3;
      background: #141414;
      overflow: hidden;
      position: relative;
    }
    .story-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .story-image .sketch-tag {
      position: absolute;
      bottom: 12px;
      left: 12px;
      background: rgba(10,10,10,0.6);
      backdrop-filter: blur(4px);
      padding: 4px 12px;
      font-size: 9px;
      letter-spacing: 0.15em;
      color: #6A6560;
      font-weight: 300;
      font-family: 'Cormorant Garamond', Georgia, serif;
      border: 0.5px solid rgba(255,255,255,0.04);
    }
    .story-text {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .story-text .title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 20px;
      font-weight: 500;
      color: #F5F0EB;
      letter-spacing: 0.04em;
    }
    .story-text .title .light {
      font-weight: 300;
      color: #6A6560;
      font-size: 16px;
      margin-left: 6px;
    }
    .story-text p {
      font-size: 14px;
      line-height: 1.8;
      color: #8A8580;
      font-weight: 300;
      letter-spacing: 0.02em;
    }
    .story-text p .highlight { color: #E8B4B8; font-weight: 400; }
    .story-text .spec-note {
      font-size: 12px;
      color: #6A6560;
      font-style: italic;
      font-weight: 300;
      padding-top: 6px;
      border-top: 0.5px solid rgba(255,255,255,0.03);
    }

    /* ===== 规格 ===== */
    .specs-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.04);
      margin-bottom: 14px;
    }
    .specs-header .label {
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #6A6560;
      font-weight: 300;
    }
    .specs-header .unit-toggle {
      display: flex;
      gap: 0;
      border: 0.5px solid rgba(255,255,255,0.06);
      overflow: hidden;
    }
    .specs-header .unit-toggle button {
      background: transparent;
      border: none;
      padding: 4px 12px;
      font-size: 11px;
      font-family: inherit;
      color: #6A6560;
      cursor: pointer;
      transition: all 0.25s ease;
      font-weight: 300;
      letter-spacing: 0.05em;
      min-width: 36px;
    }
    .specs-header .unit-toggle button.active {
      background: rgba(232,180,184,0.1);
      color: #E8B4B8;
    }
    .specs-header .unit-toggle button:active { transform: scale(0.94); }

    .specs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px 24px;
      margin-bottom: 30px;
    }
    .spec-item {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      font-size: 13px;
      font-weight: 300;
      border-bottom: 0.5px solid rgba(255,255,255,0.015);
    }
    .spec-item .l { color: #6A6560; }
    .spec-item .v { color: #F5F0EB; font-weight: 400; }

    /* ===== 材质 ===== */
    .craft {
      margin-bottom: 30px;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .craft .section-label {
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #6A6560;
      margin-bottom: 14px;
      font-weight: 300;
    }
    .craft-list { display: flex; flex-direction: column; gap: 10px; }
    .craft-item {
      display: flex;
      align-items: baseline;
      gap: 12px;
      padding: 5px 0;
      border-bottom: 0.5px solid rgba(255,255,255,0.015);
    }
    .craft-item .line {
      width: 14px;
      height: 1px;
      background: #E8B4B8;
      flex-shrink: 0;
      opacity: 0.4;
    }
    .craft-item .name { font-size: 14px; color: #F5F0EB; font-weight: 400; }
    .craft-item .detail { font-size: 12px; color: #6A6560; font-weight: 300; margin-left: auto; }

    /* ===== 场景 ===== */
    .inspiration {
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.04);
      margin-bottom: 16px;
    }
    .inspiration .section-label {
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #6A6560;
      margin-bottom: 14px;
      font-weight: 300;
    }
    .scene-scroll {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      padding-bottom: 12px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .scene-scroll::-webkit-scrollbar { height: 0; }
    .scene-card {
      min-width: 150px;
      flex-shrink: 0;
      scroll-snap-align: start;
      background: #121212;
      overflow: hidden;
    }
    .scene-card img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
    }
    .scene-card .label {
      padding: 10px 0 3px;
      font-size: 12px;
      color: #F5F0EB;
      font-weight: 400;
      letter-spacing: 0.04em;
    }
    .scene-card .sub {
      font-size: 10px;
      color: #6A6560;
      font-weight: 300;
      font-style: italic;
    }

    /* ===== 发现更多 ===== */
    .explore-more {
      padding-top: 28px;
      border-top: 1px solid rgba(255,255,255,0.04);
      margin-top: 8px;
      margin-bottom: 20px;
    }
    .explore-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }
    .explore-label {
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #6A6560;
      font-weight: 300;
    }
    .explore-view-all {
      font-size: 11px;
      color: #6A6560;
      text-decoration: none;
      letter-spacing: 0.05em;
      font-weight: 300;
      transition: color 0.3s;
    }
    .explore-view-all:active { color: #E8B4B8; }

    .explore-scroll {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      padding-bottom: 12px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .explore-scroll::-webkit-scrollbar { height: 0; }
    .explore-card {
      min-width: 160px;
      flex-shrink: 0;
      scroll-snap-align: start;
      background: #121212;
      overflow: hidden;
      border: 0.5px solid rgba(255,255,255,0.03);
      transition: border-color 0.3s ease;
      cursor: pointer;
    }
    .explore-card:active { border-color: rgba(232,180,184,0.15); }
    .explore-card-image {
      aspect-ratio: 1 / 1;
      background: #1A1A1A;
      overflow: hidden;
    }
    .explore-card-image img {
